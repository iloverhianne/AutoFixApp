<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_dark">

    <!-- Premium Background Glow -->
    <View
        android:id="@+id/viewGlow"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/premium_gradient"
        android:alpha="0.15"
        android:rotation="-15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-150dp"
        android:layout_marginTop="-150dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <!-- Glowing Icon Container -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">
            
            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/premium_gradient"
                android:alpha="0.2"
                android:scaleX="1.5"
                android:scaleY="1.5" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/text_high" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTOFIX"
            android:textColor="@color/text_high"
            android:textSize="36sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-condensed-light"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="PREMIUM SERVICE MANAGEMENT"
            android:textColor="@color/accent_cyan"
            android:textSize="10sp"
            android:letterSpacing="0.3"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:orientation="vertical">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/edit_text_premium"
                android:drawableStart="@android:drawable/ic_dialog_email"
                android:drawablePadding="20dp"
                android:hint="Email"
                android:inputType="textVisiblePassword|textNoSuggestions"
                android:importantForAutofill="noExcludeDescendants"
                android:privateImeOptions="nm,noMicrophoneKey"
                android:paddingHorizontal="24dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_low"
                android:drawableTint="@color/text_low"
                android:textSize="15sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:hintEnabled="false"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_low">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/edit_text_premium"
                    android:drawableStart="@android:drawable/ic_lock_idle_lock"
                    android:drawablePadding="20dp"
                    android:hint="Password"
                    android:inputType="textPassword|textNoSuggestions"
                    android:importantForAutofill="noExcludeDescendants"
                    android:privateImeOptions="nm,noMicrophoneKey"
                    android:paddingHorizontal="24dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_low"
                    android:drawableTint="@color/text_low"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/premium_gradient"
                app:backgroundTint="@null"
                android:text="AUTHENTICATE"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>