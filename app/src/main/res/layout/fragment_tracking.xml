<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_dark"
    android:orientation="vertical">

    <include layout="@layout/header_brand" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/track_progress"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:fontFamily="sans-serif-condensed-medium"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/track_subtitle"
            android:textColor="@color/text_mid"
            android:textSize="14sp" />

        <!-- Modern Search Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/text_low"
                    android:contentDescription="@string/desc_icon" />

                <EditText
                    android:id="@+id/etJobId"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="@string/hint_job_id"
                    android:inputType="number"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_low"
                    android:textSize="15sp"
                    android:importantForAutofill="no" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnTrackRepair"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    app:cardBackgroundColor="@color/primary_brand"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:text="@string/btn_track"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/cardEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="60dp">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:alpha="0.2"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/text_mid"
                    android:contentDescription="@string/no_job_selected" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/no_job_selected"
                    android:textColor="@color/text_low"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/no_job_desc"
                    android:textColor="@color/text_low"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Tracking Details (Hidden initially) -->
            <LinearLayout
                android:id="@+id/layoutTrackingDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Job Info Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_gradient_bg"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tvTrackVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Vehicle: ABC-1234 (Toyota Vios)"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-condensed"
                            android:textStyle="bold"
                            tools:text="Vehicle: ABC-1234 (Toyota Vios)" />

                        <View 
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/glass_border"
                            android:layout_marginVertical="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/status_label"
                                android:textColor="@color/text_mid"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvTrackStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/status_badge_bg"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="6dp"
                                android:text="IN PROGRESS"
                                android:textColor="@color/primary_brand"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                tools:text="IN PROGRESS" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/est_cost_label"
                                android:textColor="@color/text_mid"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvTrackTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱1,500.00"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="₱1,500.00" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Timeline Logs -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:text="@string/timeline_label"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
