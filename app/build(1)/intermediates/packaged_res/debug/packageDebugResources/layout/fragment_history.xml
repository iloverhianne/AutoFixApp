<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_dark"
    android:orientation="vertical">

    <include layout="@layout/header_brand" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/activity_history"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:fontFamily="sans-serif-condensed-medium"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/history_subtitle"
            android:textColor="@color/text_mid"
            android:textSize="14sp" />

        <!-- Modern Tab Toggle -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <RadioGroup
                android:id="@+id/rgTabs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="4dp">

                <RadioButton
                    android:id="@+id/rbAppointments"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/tab_selector"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:text="@string/tab_bookings"
                    android:textColor="@color/tab_text_selector"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbRepairs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/tab_selector"
                    android:button="@null"
                    android:checked="false"
                    android:gravity="center"
                    android:text="@string/tab_services"
                    android:textColor="@color/tab_text_selector"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbPayments"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/tab_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="@string/tab_payments"
                    android:textColor="@color/tab_text_selector"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RadioGroup>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAppointments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_appointment_history" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            android:visibility="gone"
            tools:listitem="@layout/item_history" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPayments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            android:visibility="gone"
            tools:listitem="@layout/item_payment_history" />

    </FrameLayout>

</LinearLayout>
